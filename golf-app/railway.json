{
  "$schema": "https://railway.app/railway-schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && node --experimental-sqlite node_modules/.bin/next build"
  },
  "deploy": {
    "startCommand": "node --experimental-sqlite scripts/start.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
