# Copy this to .env.local and fill in values

# Required: Secret key for JWT signing (min 32 chars, random string)
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-here

# Required on Railway: Path to SQLite database file.
# On Railway, add a Volume mounted at /data, then set:
# DATABASE_PATH=/data/golf.db
# Without this, the database resets on every deploy.
DATABASE_PATH=./data/golf.db

# Optional: Invite codes for registration
INVITE_CODE=sandbaggers
ADMIN_INVITE_CODE=co-admin

# Optional: GHIN API token (from USGA/Golf Genius)
GHIN_TOKEN=your-ghin-api-token-here

# Optional: App URL (for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
