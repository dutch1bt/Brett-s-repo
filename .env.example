# Copy this file to .env and fill in your values
ANTHROPIC_API_KEY=your_api_key_here

# Golf club configuration
GOLF_CLUB_NAME=My Local Golf Club
GOLF_CLUB_BOOKING_URL=https://your-club-booking-site.com
GOLF_CLUB_MEMBER_ID=your_member_id
GOLF_CLUB_MEMBER_PIN=your_pin

# Auto-reserve configuration (used by auto_reserve.py)
AUTO_RESERVE_PLAYERS=1
AUTO_RESERVE_PLAYER_NAMES=Brett  # comma-separated if multiple, e.g. Brett,John
